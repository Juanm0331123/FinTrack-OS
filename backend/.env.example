PORT=4000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fintrack_os?schema=public"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
TRUST_PROXY=false
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
EMAIL_VERIFICATION_TTL=1d
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
EXPOSE_DEV_AUTH_TOKENS=true
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/oauth/google/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3001/api/auth/oauth/github/callback
