generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING_VERIFICATION
}

enum UserRole {
  USER
  ADMIN
}

enum AccountType {
  CASH
  BANK_ACCOUNT
  CREDIT_CARD
  SAVINGS
  DIGITAL_WALLET
  OTHER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  DEBT_PAYMENT
  SAVING_CONTRIBUTION
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum DebtStatus {
  ACTIVE
  PAID
  DEFAULTED
  CANCELED
}

enum DebtType {
  CREDIT_CARD
  PERSONAL_LOAN
  MORTGAGE
  AUTO_LOAN
  STUDENT_LOAN
  LINE_OF_CREDIT
  OTHER
}

enum SavingGoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELED
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum OAuthProvider {
  GOOGLE
  GITHUB
}

model User {
  id                    String                    @id @default(uuid()) @db.Uuid
  firstName             String                    @map("first_name") @db.VarChar(100)
  lastName              String?                   @map("last_name") @db.VarChar(100)
  email                 String                    @unique @db.VarChar(255)
  passwordHash          String                    @map("password_hash") @db.VarChar(255)
  status                UserStatus                @default(PENDING_VERIFICATION)
  role                  UserRole                  @default(USER)
  preferredCurrencyCode String                    @default("COP") @map("preferred_currency_code") @db.Char(3)
  timezone              String                    @default("UTC") @db.VarChar(100)
  lastLoginAt           DateTime?                 @map("last_login_at")
  deletedAt             DateTime?                 @map("deleted_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  authTokens            AuthToken[]
  categories            Category[]
  debts                 Debt[]
  financialAccounts     FinancialAccount[]
  monthlyProfiles       MonthlyFinancialProfile[]
  oauthAccounts         OAuthAccount[]
  refreshTokens         RefreshToken[]
  savingGoals           SavingGoal[]
  transactions          Transaction[]

  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  deviceName String?   @map("device_name") @db.VarChar(150)
  ipAddress  String?   @map("ip_address") @db.VarChar(100)
  userAgent  String?   @map("user_agent")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuthToken {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  type      AuthTokenType
  tokenHash String        @unique @map("token_hash") @db.VarChar(255)
  tokenSalt String?       @map("token_salt") @db.VarChar(255)
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  revokedAt DateTime?     @map("revoked_at")
  createdAt DateTime      @default(now()) @map("created_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, type, revokedAt, usedAt])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model OAuthAccount {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  provider          OAuthProvider
  providerAccountId String        @map("provider_account_id") @db.VarChar(255)
  providerEmail     String?       @map("provider_email") @db.VarChar(255)
  displayName       String?       @map("display_name") @db.VarChar(255)
  avatarUrl         String?       @map("avatar_url")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model FinancialAccount {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  name            String        @db.VarChar(150)
  type            AccountType
  status          AccountStatus @default(ACTIVE)
  institutionName String?       @map("institution_name") @db.VarChar(150)
  currencyCode    String        @default("COP") @map("currency_code") @db.Char(3)
  openingBalance  Decimal       @default(0) @map("opening_balance") @db.Decimal(14, 2)
  creditLimit     Decimal?      @map("credit_limit") @db.Decimal(14, 2)
  isDefault       Boolean       @default(false) @map("is_default")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  linkedDebt      Debt?         @relation("DebtLinkedAccount")
  transactions    Transaction[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@map("financial_accounts")
}

model Category {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String?       @map("user_id") @db.Uuid
  name         String        @db.VarChar(120)
  kind         CategoryKind
  icon         String?       @db.VarChar(100)
  color        String?       @db.VarChar(20)
  isSystem     Boolean       @default(false) @map("is_system")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  transactions Transaction[]
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, name])
  @@index([userId])
  @@index([kind])
  @@index([isSystem])
  @@map("categories")
}

model Debt {
  id                   String            @id @default(uuid()) @db.Uuid
  userId               String            @map("user_id") @db.Uuid
  linkedAccountId      String?           @unique @map("linked_account_id") @db.Uuid
  name                 String            @db.VarChar(150)
  lenderName           String?           @map("lender_name") @db.VarChar(150)
  type                 DebtType
  status               DebtStatus        @default(ACTIVE)
  currencyCode         String            @default("COP") @map("currency_code") @db.Char(3)
  originalAmount       Decimal           @map("original_amount") @db.Decimal(14, 2)
  currentPrincipal     Decimal           @map("current_principal") @db.Decimal(14, 2)
  interestRateAnnual   Decimal?          @map("interest_rate_annual") @db.Decimal(5, 2)
  minimumPaymentAmount Decimal?          @map("minimum_payment_amount") @db.Decimal(14, 2)
  statementDay         Int?              @map("statement_day")
  dueDay               Int?              @map("due_day")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  closedAt             DateTime?         @map("closed_at")
  linkedAccount        FinancialAccount? @relation("DebtLinkedAccount", fields: [linkedAccountId], references: [id], onDelete: SetNull)
  transactions         Transaction[]
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("debts")
}

model SavingGoal {
  id                 String           @id @default(uuid()) @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  name               String           @db.VarChar(150)
  status             SavingGoalStatus @default(ACTIVE)
  currencyCode       String           @default("COP") @map("currency_code") @db.Char(3)
  targetAmount       Decimal          @map("target_amount") @db.Decimal(14, 2)
  currentSavedAmount Decimal          @default(0) @map("current_saved_amount") @db.Decimal(14, 2)
  targetDate         DateTime?        @map("target_date") @db.Date
  priority           Int?
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  completedAt        DateTime?        @map("completed_at")
  transactions       Transaction[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("saving_goals")
}

model Transaction {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  accountId       String            @map("account_id") @db.Uuid
  categoryId      String?           @map("category_id") @db.Uuid
  debtId          String?           @map("debt_id") @db.Uuid
  savingGoalId    String?           @map("saving_goal_id") @db.Uuid
  transferGroupId String?           @map("transfer_group_id") @db.Uuid
  type            TransactionType
  status          TransactionStatus @default(CONFIRMED)
  title           String            @db.VarChar(180)
  description     String?
  amount          Decimal           @db.Decimal(14, 2)
  currencyCode    String            @default("COP") @map("currency_code") @db.Char(3)
  occurredOn      DateTime          @map("occurred_on") @db.Date
  effectiveMonth  String            @map("effective_month") @db.VarChar(7)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  account         FinancialAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category        Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  debt            Debt?             @relation(fields: [debtId], references: [id], onDelete: Restrict)
  savingGoal      SavingGoal?       @relation(fields: [savingGoalId], references: [id], onDelete: Restrict)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
  @@index([debtId])
  @@index([savingGoalId])
  @@index([type])
  @@index([status])
  @@index([occurredOn])
  @@index([effectiveMonth])
  @@index([transferGroupId])
  @@map("transactions")
}

model MonthlyFinancialProfile {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  yearMonth           String   @map("year_month") @db.VarChar(7)
  needsTargetPct      Decimal  @default(50) @map("needs_target_pct") @db.Decimal(5, 2)
  wantsTargetPct      Decimal  @default(30) @map("wants_target_pct") @db.Decimal(5, 2)
  savingsTargetPct    Decimal  @default(20) @map("savings_target_pct") @db.Decimal(5, 2)
  targetSavingsAmount Decimal? @map("target_savings_amount") @db.Decimal(14, 2)
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, yearMonth])
  @@index([userId])
  @@index([yearMonth])
  @@map("monthly_financial_profiles")
}
